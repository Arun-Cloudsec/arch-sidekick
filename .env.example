# Copy this file to .env for local development.
# In Railway, set these in the "Variables" tab (DO NOT commit .env to git).

# Required: your Anthropic API key
# Get one at https://console.anthropic.com/ → API Keys → Create Key
# Then add credits at https://console.anthropic.com/ → Plans & Billing
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Optional: app name shown in logs
APP_NAME=Arch Sidekick

# Optional: site URL (Railway injects automatically, set for local dev)
SITE_URL=http://localhost:3000

# Optional: port (Railway sets PORT automatically, don't override there)
PORT=3000

# Note: Azure Retail Prices API requires no key — it's public.
