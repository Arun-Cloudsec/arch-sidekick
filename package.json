{
  "name": "arch-sidekick",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "AI Solution Architect Sidekick — plain-English to Azure/AWS/GCP reference architecture with multi-model consensus, alternative tiers, and conversational refinement",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "node --watch --env-file-if-exists=.env server.js",
    "build": "vite build",
    "start": "node --env-file-if-exists=.env server.js",
    "preview": "vite preview"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "express": "^4.21.2",
    "lucide-react": "^0.468.0",
    "pptxgenjs": "^3.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.5"
  },
  "engines": {
    "node": ">=20.12.0"
  }
}
